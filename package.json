{
  "name": "qs-collection-system",
  "version": "1.0.0",
  "private": true,
  "description": "问卷收集系统",
  "templateInfo": {
    "name": "qlume-taroify",
    "typescript": false,
    "css": "less"
  },
  "scripts": {
    "build:weapp": "NODE_ENV=production taro build --type weapp",
    "build:weapp:prod": "NODE_ENV=production taro build --type weapp",
    "dev:weapp": "NODE_ENV=development taro build --type weapp --watch",
    "dev:weapp:prod": "NODE_ENV=production npm run build:weapp -- --watch",
    "test:iam-contracts": "node scripts/check-iam-contracts.js",
    "test:portal-contracts": "node scripts/check-portal-contracts.js",
    "test:collection-personality-contracts": "node scripts/check-collection-personality-contracts.js",
    "test:collection-behavior-contracts": "node scripts/check-collection-behavior-contracts.js",
    "test:collection-contracts": "node scripts/check-collection-contracts.js && node scripts/test-medical-report-mapper.cjs",
    "test:medical-report-mapper": "node scripts/test-medical-report-mapper.cjs",
    "test:personality-seams": "node scripts/test-personality-seams.js",
    "test:contracts": "npm run test:iam-contracts && npm run test:portal-contracts && npm run test:collection-personality-contracts && npm run test:collection-behavior-contracts && npm run test:collection-contracts && npm run test:personality-seams",
    "test:ui": "jest --runInBand",
    "test:ui:watch": "jest --watch",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "check:package-size": "node scripts/check-package-size.cjs",
    "check:ui-boundaries": "node scripts/check-ui-boundaries.cjs",
    "check:ui-assets": "node scripts/check-ui-assets.cjs",
    "report:ui-governance": "node scripts/report-ui-governance.cjs",
    "verify:frontend": "npm run typecheck:strict && npm run test:ui && npm run test:contracts && npm run check:ui-boundaries && npm run check:ui-assets && npm run build:weapp && npm run check:package-size && git diff --check"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "",
  "engines": {
    "node": ">=14 <17",
    "npm": ">=6"
  },
  "dependencies": {
    "@babel/runtime": "^7.23.9",
    "@taroify/core": "0.9.2",
    "@taroify/icons": "0.9.2",
    "@tarojs/components": "3.6.25",
    "@tarojs/plugin-platform-weapp": "3.6.25",
    "@tarojs/react": "3.6.25",
    "@tarojs/taro": "3.6.25",
    "lodash": "^4.17.21",
    "lottie-miniprogram": "^1.0.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@tarojs/cli": "3.6.25",
    "@tarojs/mini-runner": "3.6.25",
    "@tarojs/plugin-framework-react": "^3.6.25",
    "@tarojs/webpack-runner": "3.6.25",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "babel-jest": "29.7.0",
    "babel-preset-taro": "3.6.25",
    "eslint": "^8.56.0",
    "eslint-config-taro": "3.6.25",
    "eslint-plugin-import": "^2.12.0",
    "eslint-plugin-react": "^7.8.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "29.7.0",
    "react-test-renderer": "18.2.0",
    "stylelint": "14.16.1",
    "typescript": "^5.9.3"
  }
}
